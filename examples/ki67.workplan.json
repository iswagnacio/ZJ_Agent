{
  "experimentName": "Ki67免疫荧光阳性率分析",
  "inputMode": "single_rgb_merged_image",
  "analysisGoal": "统计荧光图像中Ki67阳性细胞占总细胞的比例，即Ki67阳性率。",
  "imageInference": {
    "imageModality": "fluorescence",
    "experimentType": "cellular_analysis,positive_rate_analysis,fluorescence_analysis",
    "reasoning": [
      "图像为荧光RGB合并图，蓝色通道为DAPI标记的细胞核，红色通道为Ki67阳性信号，因此采用rgb_split方法拆分通道。",
      "使用Cellpose模型在DAPI通道分割所有细胞核，作为总细胞统计的基础target。",
      "基于总细胞核target，测量每个细胞核对应Ki67红色通道的平均强度，筛选出Ki67阳性细胞亚群。",
      "最终通过阳性细胞数除以总细胞数计算得到Ki67阳性率。"
    ]
  },
  "workplanSceneType": "target_based_analysis",
  "channels": [
    {
      "channelId": "ch0",
      "channelName": "Ki67阳性信号",
      "semanticRole": "positive_signal_channel"
    },
    {
      "channelId": "ch1",
      "channelName": "unused_green_channel",
      "semanticRole": "unused_or_background_channel"
    },
    {
      "channelId": "ch2",
      "channelName": "DAPI细胞核",
      "semanticRole": "nucleus_marker"
    }
  ],
  "targets": [
    {
      "targetName": "total_nuclei",
      "targetType": "nucleus",
      "description": "DAPI通道通过Cellpose分割得到的所有细胞核ROI集合，代表总细胞数量。"
    },
    {
      "targetName": "ki67_positive_nuclei",
      "targetType": "positive_cell_subpopulation",
      "description": "总细胞核中Ki67红色通道平均强度高于阈值的阳性细胞ROI集合。"
    }
  ],
  "jobs": [
    {
      "jobId": "job_00",
      "jobName": "RGB荧光通道拆分",
      "jobType": "pic_split",
      "stepDescript": "将输入的荧光RGB合并图拆分为Ki67红色通道、未使用绿色通道和DAPI蓝色通道。",
      "inputs": {
        "imageModality": "fluorescence",
        "sourceImageType": "single_rgb_merged_image"
      },
      "outputs": {
        "generatedChannels": [
          "ch0",
          "ch1",
          "ch2"
        ]
      },
      "picSplitPlan": {
        "splitMethod": "rgb_split",
        "channelMapping": {
          "ch0": "Ki67阳性信号",
          "ch1": "unused_green_channel",
          "ch2": "DAPI细胞核"
        },
        "recommended": true,
        "outputOptions": {
          "returnChannelStoredFiles": true,
          "returnChannelBase64": false,
          "returnChannelPseudoBase64": true
        }
      }
    },
    {
      "jobId": "job_01",
      "jobName": "建立总细胞核target",
      "jobType": "create_target",
      "stepDescript": "在DAPI通道上使用Cellpose识别图片中的所有细胞核，建立total_nuclei作为总细胞ROI集合。",
      "inputs": {
        "channelId": [
          "ch2"
        ],
        "sourceTargetNames": []
      },
      "outputs": {
        "targetName": "total_nuclei"
      },
      "createTargetPlan": {
        "recommendedSegmentMethod": "cellpose",
        "segmentMethodReason": "Cellpose模型适用于DAPI荧光图像的细胞核实例分割，可准确识别每个独立细胞核作为总细胞统计基础。",
        "sourceTargetNames": [],
        "variant": [],
        "variantReasoning": "total_nuclei为直接由DAPI通道分割得到的基础细胞核target，不需要生成空间变体。",
        "measureOn": [],
        "measureFeatures": [],
        "filterConditions": [],
        "filterBasis": "",
        "cellposeParams": {
          "model": "zhijing_if_nuclei",
          "diameter": 30.0,
          "flowThreshold": {
            "min": 0.0,
            "max": 1.0
          },
          "cellprobThreshold": {
            "min": -6.0,
            "max": 6.0
          }
        },
        "imagePreprocess": {
          "smooth": 0,
          "blur": 0,
          "sharp": 0,
          "invert": false
        }
      }
    },
    {
      "jobId": "job_02",
      "jobName": "建立Ki67阳性细胞target",
      "jobType": "create_target",
      "stepDescript": "基于total_nuclei总细胞核target，测量每个细胞核在Ki67红色通道的平均强度，筛选出阳性细胞并绑定为ki67_positive_nuclei target。",
      "inputs": {
        "channelId": [
          "ch0"
        ],
        "sourceTargetNames": [
          "total_nuclei"
        ]
      },
      "outputs": {
        "targetName": "ki67_positive_nuclei"
      },
      "createTargetPlan": {
        "recommendedSegmentMethod": "",
        "segmentMethodReason": "",
        "sourceTargetNames": [
          "total_nuclei"
        ],
        "variant": [],
        "variantReasoning": "Ki67阳性细胞由总细胞核筛选得到，不需要生成空间变体。",
        "measureOn": [
          "ch0"
        ],
        "measureFeatures": [
          "MEAN"
        ],
        "filterConditions": [
          {
            "channelId": "ch0",
            "feature": "MEAN",
            "operator": ">",
            "threshold": 50,
            "reason": "Ki67红色通道平均强度高于阈值50判定为阳性细胞，符合荧光阳性信号的常规判定阈值。"
          }
        ],
        "filterBasis": "测量每个细胞核在Ki67红色通道的平均强度，保留强度高于阈值的细胞作为阳性亚群。"
      }
    },
    {
      "jobId": "job_99",
      "jobName": "计算Ki67阳性率",
      "jobType": "formula",
      "stepDescript": "基于总细胞数和Ki67阳性细胞数计算Ki67阳性率，并输出相关统计指标。",
      "inputs": {
        "targetInputs": [
          {
            "targetName": "total_nuclei",
            "metric": "COUNT",
            "role": "total_cell_count"
          },
          {
            "targetName": "ki67_positive_nuclei",
            "metric": "COUNT",
            "role": "positive_cell_count"
          }
        ]
      },
      "outputs": {
        "resultName": "ki67_positive_rate_result"
      },
      "formulaPlan": {
        "expression": "totalCellCount = total_nuclei.COUNT; positiveCellCount = ki67_positive_nuclei.COUNT; ki67PositiveRate = positiveCellCount / totalCellCount * 100",
        "reportFields": [
          {
            "fieldName": "totalCellCount",
            "displayName": "总细胞数",
            "unit": "个",
            "description": "DAPI通道识别得到的所有细胞核数量，代表统计范围内的总细胞数。"
          },
          {
            "fieldName": "positiveCellCount",
            "displayName": "Ki67阳性细胞数",
            "unit": "个",
            "description": "Ki67红色通道平均强度高于阈值的阳性细胞数量。"
          },
          {
            "fieldName": "ki67PositiveRate",
            "displayName": "Ki67阳性率",
            "unit": "%",
            "description": "Ki67阳性细胞数占总细胞数的百分比，公式为阳性细胞数/总细胞数×100。"
          }
        ]
      }
    }
  ]
}