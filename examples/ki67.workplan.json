{
  "experimentName": "胰岛Ki67增殖比例分析",
  "inputMode": "single_rgb_merged_image",
  "analysisGoal": "统计胰岛内Ki67阳性细胞核的比例",
  "imageInference": {
    "imageModality": "fluorescence",
    "experimentType": "cellular",
    "reasoning": [
      "根据图像荧光颜色分布与用户描述，判断为荧光细胞实验。"
    ]
  },
  "workplanSceneType": "target_based_analysis",
  "channels": [
    {
      "channelId": "ch0",
      "channelName": "Ki67",
      "semanticRole": "proliferation_marker"
    },
    {
      "channelId": "ch1",
      "channelName": "islet_marker",
      "semanticRole": "region_marker"
    },
    {
      "channelId": "ch2",
      "channelName": "DAPI",
      "semanticRole": "nucleus_marker"
    }
  ],
  "targets": [
    {
      "targetName": "total_dapi_roi",
      "targetType": "nucleus",
      "description": "全视野内所有DAPI标记的细胞核ROI。"
    },
    {
      "targetName": "total_dapi_in_islet_roi",
      "targetType": "nucleus",
      "description": "胰岛区域内的DAPI标记细胞核ROI，由全视野细胞核筛选得到。"
    },
    {
      "targetName": "ki67_positive_dapi_in_islet_roi",
      "targetType": "positive_nucleus",
      "description": "胰岛区域内Ki67阳性的DAPI标记细胞核ROI，由胰岛内细胞核筛选得到。"
    }
  ],
  "jobs": [
    {
      "jobId": "job_00",
      "jobName": "通道拆分",
      "jobType": "pic_split",
      "stepDescript": "拆分RGB荧光图为Ki67、胰岛标记、DAPI三个独立通道",
      "inputs": {
        "imageModality": "fluorescence",
        "sourceImageType": "single_rgb_merged_image"
      },
      "outputs": {
        "generatedChannels": [
          "Ki67",
          "islet_marker",
          "DAPI"
        ]
      },
      "picSplitPlan": {
        "splitMethod": "rgb_split",
        "channelMapping": {
          "ch0": "Ki67",
          "ch1": "islet_marker",
          "ch2": "DAPI"
        },
        "recommended": true
      }
    },
    {
      "jobId": "job_01",
      "jobName": "分割全视野细胞核",
      "jobType": "create_target",
      "stepDescript": "在DAPI通道上使用Cellpose分割全视野内的所有细胞核，建立基础目标集合",
      "inputs": {
        "channelId": [
          "ch2"
        ],
        "sourceTargetNames": []
      },
      "outputs": {
        "targetName": "total_dapi_roi"
      },
      "createTargetPlan": {
        "recommendedSegmentMethod": "cellpose",
        "segmentMethodReason": "Cellpose对细胞核分割具有较高准确性，适合荧光图像中的细胞核检测",
        "cellposeParams": {
          "model": "zhijing_if_nuclei",
          "diameter": 23,
          "flowThreshold": {
            "min": 0.0,
            "max": 1.0
          },
          "cellprobThreshold": {
            "min": -6.0,
            "max": 6.0
          }
        },
        "measureFeatures": [],
        "filterBasis": ""
      }
    },
    {
      "jobId": "job_02",
      "jobName": "筛选胰岛内细胞核",
      "jobType": "create_target",
      "stepDescript": "基于全视野细胞核集合，筛选出胰岛区域内的细胞核",
      "inputs": {
        "channelId": [
          "ch1"
        ],
        "sourceTargetNames": [
          "total_dapi_roi"
        ],
        "variant": [
          {
            "boundaryModes": "on_bound",
            "offsetLevels": "0.2"
          }
        ]
      },
      "outputs": {
        "targetName": "total_dapi_in_islet_roi"
      },
      "createTargetPlan": {
        "recommendedSegmentMethod": "",
        "segmentMethodReason": "",
        "measureOn": [
          "ch1"
        ],
        "measureFeatures": [
          "MEAN"
        ],
        "filterConditions": [
          {
            "channelId": "ch1",
            "feature": "MEAN",
            "operator": ">",
            "threshold": "23"
          }
        ],
        "filterBasis": "筛选胰岛标记通道信号强度高于阈值的细胞核"
      }
    },
    {
      "jobId": "job_03",
      "jobName": "筛选Ki67阳性细胞核",
      "jobType": "create_target",
      "stepDescript": "基于胰岛内细胞核集合，筛选出Ki67阳性的细胞核",
      "inputs": {
        "channelId": [
          "ch0"
        ],
        "sourceTargetNames": [
          "total_dapi_in_islet_roi"
        ],
        "variant": [
          {
            "boundaryModes": "in_bound",
            "offsetLevels": "0.1"
          }
        ]
      },
      "outputs": {
        "targetName": "ki67_positive_dapi_in_islet_roi"
      },
      "createTargetPlan": {
        "recommendedSegmentMethod": "",
        "segmentMethodReason": "",
        "measureOn": [
          "ch0"
        ],
        "measureFeatures": [
          "MEAN"
        ],
        "filterConditions": [
          {
            "channelId": "ch0",
            "feature": "MEAN",
            "operator": ">",
            "threshold": "75"
          }
        ],
        "filterBasis": "筛选Ki67通道信号强度高于阈值的细胞核"
      }
    },
    {
      "jobId": "job_99",
      "jobName": "计算增殖比例",
      "jobType": "formula",
      "stepDescript": "计算胰岛内Ki67阳性细胞核的比例",
      "inputs": {
        "targetInputs": [
          {
            "targetName": "ki67_positive_dapi_in_islet_roi",
            "metric": "COUNT",
            "role": "numerator"
          },
          {
            "targetName": "total_dapi_in_islet_roi",
            "metric": "COUNT",
            "role": "denominator"
          }
        ]
      },
      "outputs": {
        "resultName": "ki67_positive_ratio_in_islet"
      },
      "formulaPlan": {
        "expression": "ki67_positive_dapi_in_islet_roi / total_dapi_in_islet_roi",
        "reportFields": [
          "total_dapi_in_islet_count",
          "ki67_positive_dapi_count",
          "ki67_positive_ratio_in_islet"
        ]
      }
    }
  ]
}