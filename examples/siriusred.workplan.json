{
  "experimentName": "天狼星红染色胶原纤维面积分析",
  "inputMode": "single_rgb_brightfield_image",
  "analysisGoal": "统计明场天狼星红染色组织切片中胶原纤维的总面积",
  "imageInference": {
    "imageModality": "brightfield",
    "experimentType": "tissue_region_analysis,area_analysis",
    "reasoning": [
      "图像为明场天狼星红染色组织切片，紫红色信号为目标胶原纤维区域，蓝色为苏木精染色的细胞核",
      "采用颜色反卷积拆分染色通道，通过阈值分割提取所有胶原纤维阳性区域",
      "测量胶原纤维区域的总面积作为最终分析结果"
    ]
  },
  "workplanSceneType": "target_based_analysis",
  "channels": [
    {
      "channelId": "ch0",
      "channelName": "天狼星红（胶原纤维）",
      "semanticRole": "collagen_signal_channel"
    },
    {
      "channelId": "ch1",
      "channelName": "苏木精（细胞核）",
      "semanticRole": "nucleus_channel"
    },
    {
      "channelId": "ch2",
      "channelName": "背景残留",
      "semanticRole": "background_channel"
    }
  ],
  "targets": [
    {
      "targetName": "total_collagen_roi",
      "targetType": "collagen_region",
      "description": "通过阈值分割提取的所有紫红色胶原纤维区域ROI集合"
    }
  ],
  "jobs": [
    {
      "jobId": "job_00",
      "jobName": "颜色反卷积拆分通道",
      "jobType": "pic_split",
      "stepDescript": "对输入的明场天狼星红染色图像执行颜色反卷积，拆分出天狼星红（胶原纤维）、苏木精（细胞核）和背景残留三个通道",
      "inputs": {
        "imageModality": "brightfield",
        "sourceImageType": "single_rgb_brightfield_image"
      },
      "outputs": {
        "generatedChannels": [
          "天狼星红（胶原纤维）",
          "苏木精（细胞核）",
          "背景残留"
        ]
      },
      "picSplitPlan": {
        "splitMethod": "color_deconvolution",
        "colorDeconvParams": {
          "matrix": "Masson Trichrome"
        },
        "channelMapping": {
          "ch0": "天狼星红（胶原纤维）",
          "ch1": "苏木精（细胞核）",
          "ch2": "背景残留"
        },
        "recommended": true
      }
    },
    {
      "jobId": "job_01",
      "jobName": "分割提取胶原纤维区域",
      "jobType": "create_target",
      "stepDescript": "在天狼星红（胶原纤维）通道上使用阈值分割提取所有阳性胶原纤维区域，建立胶原纤维目标集合",
      "inputs": {
        "channelId": [
          "ch0"
        ],
        "sourceTargetNames": []
      },
      "outputs": {
        "targetName": "total_collagen_roi"
      },
      "createTargetPlan": {
        "recommendedSegmentMethod": "threshold",
        "segmentMethodReason": "胶原纤维在天狼星红通道中表现为低灰度阳性染色区域，适合使用阈值分割提取完整区域",
        "sourceTargetNames": [],
        "variant": [],
        "variantReasoning": "",
        "measureOn": [],
        "measureFeatures": [],
        "filterConditions": [],
        "filterBasis": "",
        "thresholdParams": {
          "thresholdMin": 0,
          "thresholdMax": 180
        },
        "imagePreprocess": {
          "smooth": 2,
          "blur": 0,
          "sharp": 0,
          "invert": false
        },
        "binaryPostprocess": {
          "fillHole": true,
          "watershed": false
        },
        "analyzeParticlesParams": {
          "sizeMin": 1,
          "sizeMax": 10000000,
          "circularityMin": 0.0,
          "circularityMax": 1.0,
          "excludeOnEdges": false,
          "includeHoles": true
        }
      }
    },
    {
      "jobId": "job_99",
      "jobName": "计算胶原纤维总面积",
      "jobType": "formula",
      "stepDescript": "测量提取的胶原纤维区域总面积并输出结果",
      "inputs": {
        "targetInputs": [
          {
            "targetName": "total_collagen_roi",
            "metric": "AREA_SUM",
            "role": "total_collagen_area"
          }
        ]
      },
      "outputs": {
        "resultName": "collagen_area_result"
      },
      "formulaPlan": {
        "expression": "collagenTotalArea = total_collagen_roi.AREA_SUM",
        "reportFields": [
          {
            "fieldName": "collagenTotalArea",
            "displayName": "胶原纤维总面积",
            "unit": "px^2",
            "description": "图片中所有天狼星红染色阳性的胶原纤维区域面积总和"
          }
        ]
      }
    }
  ]
}