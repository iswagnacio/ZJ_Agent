{
  "experimentName": "siriusred",
  "inputMode": "single_rgb_brightfield_image",
  "analysisGoal": "统计图片中Sirius Red染色标记的胶原纤维面积。",
  "imageInference": {
    "imageModality": "brightfield",
    "experimentType": "tissue_region_analysis,area_analysis,color_deconvolution_analysis",
    "reasoning": [
      "SAS配置显示染色方案为天狼星红染色，红色成分对应胶原纤维，黄色成分对应苦味酸背景下的细胞质或肌纤维，因此按明场染色图进行颜色反卷积。",
      "当前预设矩阵列表中没有明确的Sirius Red预设，本Workplan使用custom颜色反卷积方案，按胶原红和肌纤维黄色两组RGB染色向量拆分通道。",
      "胶原纤维target在胶原纤维解卷通道上使用低灰度阈值0到107分割，按截图配置保留面积大于20 px^2的组织区域。"
    ]
  },
  "workplanSceneType": "target_based_analysis",
  "channels": [
    {
      "channelId": "ch0",
      "channelName": "胶原纤维",
      "semanticRole": "collagen_fiber_channel"
    },
    {
      "channelId": "ch1",
      "channelName": "肌纤维",
      "semanticRole": "counterstain_or_muscle_fiber_channel"
    },
    {
      "channelId": "ch2",
      "channelName": "背景残留",
      "semanticRole": "residual_background_channel"
    }
  ],
  "targets": [
    {
      "targetName": "胶原纤维",
      "targetType": "collagen_fiber_region",
      "description": "图片中由Sirius Red胶原纤维通道阈值分割得到的胶原纤维ROI集合。"
    }
  ],
  "jobs": [
    {
      "jobId": "job_00",
      "jobName": "Sirius Red颜色反卷积",
      "jobType": "pic_split",
      "stepDescript": "对输入的Sirius Red明场染色图执行custom颜色反卷积，拆分胶原纤维、肌纤维和背景残留通道。",
      "inputs": {
        "imageModality": "brightfield",
        "sourceImageType": "single_rgb_brightfield_image"
      },
      "outputs": {
        "generatedChannels": [
          "ch0",
          "ch1",
          "ch2"
        ]
      },
      "picSplitPlan": {
        "splitMethod": "color_deconvolution",
        "colorDeconvParams": {
          "matrix": "custom",
          "vectorValueType": "rgb",
          "stainVectors": [
            {
              "r": 180,
              "g": 30,
              "b": 35
            },
            {
              "r": 230,
              "g": 210,
              "b": 30
            }
          ]
        },
        "channelMapping": {
          "ch0": "胶原纤维",
          "ch1": "肌纤维",
          "ch2": "背景残留"
        },
        "recommended": true,
        "outputOptions": {
          "returnChannelStoredFiles": true,
          "returnChannelBase64": false,
          "returnChannelPseudoBase64": true
        }
      }
    },
    {
      "jobId": "job_01",
      "jobName": "建立胶原纤维target",
      "jobType": "create_target",
      "stepDescript": "在胶原纤维解卷通道上使用阈值0到107分割胶原纤维阳性区域，建立胶原纤维target。",
      "inputs": {
        "channelId": [
          "ch0"
        ],
        "sourceTargetNames": []
      },
      "outputs": {
        "targetName": "胶原纤维"
      },
      "createTargetPlan": {
        "recommendedSegmentMethod": "threshold",
        "segmentMethodReason": "Sirius Red胶原纤维在自定义颜色反卷积后的胶原通道中作为目标染色信号进行分割；截图配置使用0到107的低灰度阈值范围提取胶原纤维区域。",
        "sourceTargetNames": [],
        "variant": [],
        "variantReasoning": "胶原纤维target由胶原纤维通道直接阈值分割得到，不基于已有target生成空间变体。",
        "measureOn": [],
        "measureFeatures": [],
        "filterConditions": [],
        "filterBasis": "",
        "thresholdParams": {
          "thresholdMin": 0,
          "thresholdMax": 107
        },
        "imagePreprocess": {
          "smooth": 0,
          "blur": 0,
          "sharp": 0,
          "invert": false
        },
        "binaryPostprocess": {
          "fillHole": false,
          "watershed": true
        },
        "analyzeParticlesParams": {
          "sizeMin": 20.0,
          "sizeMax": 10000000,
          "circularityMin": 0.0,
          "circularityMax": 1.0,
          "excludeOnEdges": false,
          "includeHoles": true
        }
      }
    },
    {
      "jobId": "job_99",
      "jobName": "计算胶原纤维面积",
      "jobType": "formula",
      "stepDescript": "统计胶原纤维target的面积总和，输出胶原纤维面积指标。",
      "inputs": {
        "targetInputs": [
          {
            "targetName": "胶原纤维",
            "metric": "AREA_SUM",
            "role": "collagen_fiber_area"
          }
        ]
      },
      "outputs": {
        "resultName": "collagen_fiber_area_summary"
      },
      "formulaPlan": {
        "expression": "collagenFiberArea = 胶原纤维.AREA_SUM",
        "reportFields": [
          {
            "fieldName": "collagenFiberArea",
            "displayName": "胶原纤维面积",
            "unit": "px^2",
            "description": "胶原纤维target的面积总和。"
          }
        ]
      }
    }
  ]
}