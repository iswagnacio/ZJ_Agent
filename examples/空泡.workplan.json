{
  "experimentName": "HE染色组织空泡面积分级计数分析",
  "inputMode": "single_rgb_brightfield_image",
  "analysisGoal": "对明场HE染色组织切片的空泡结构按指定面积范围分级，统计各分级对应的空泡数量。",
  "imageInference": {
    "imageModality": "brightfield",
    "experimentType": "vacuole_analysis,area_grading_analysis,color_deconvolution_analysis",
    "reasoning": [
      "输入为明场HE染色组织切片，使用H&E预设矩阵执行颜色反卷积，拆分苏木精细胞核通道、伊红细胞质通道和背景残留通道。",
      "空泡结构在细胞质通道中表现为类圆形低信号区域，采用zhijing_vacuoles专用Cellpose模型分割所有空泡候选区域。",
      "测量每个空泡的面积参数，按用户指定的两个面积范围分级筛选目标，最终统计各分级的空泡数量。"
    ]
  },
  "workplanSceneType": "target_based_analysis",
  "channels": [
    {
      "channelId": "ch0",
      "channelName": "苏木精（细胞核）",
      "semanticRole": "nucleus_channel"
    },
    {
      "channelId": "ch1",
      "channelName": "伊红（细胞质）",
      "semanticRole": "cytoplasm_channel"
    },
    {
      "channelId": "ch2",
      "channelName": "背景残留",
      "semanticRole": "residual_background_channel"
    }
  ],
  "targets": [
    {
      "targetName": "tg1",
      "targetType": "vacuole_region",
      "description": "在细胞质通道上使用Cellpose zhijing_vacuoles模型分割得到的所有空泡候选ROI集合。"
    },
    {
      "targetName": "tg2",
      "targetType": "graded_vacuole",
      "description": "从tg1中筛选得到的面积范围为0.0~5029.0 px²的小空泡ROI集合。"
    },
    {
      "targetName": "tg3",
      "targetType": "graded_vacuole",
      "description": "从tg1中筛选得到的面积范围为5029.0~12909.0 px²的中空泡ROI集合。"
    }
  ],
  "jobs": [
    {
      "jobId": "job_00",
      "jobName": "HE染色颜色反卷积",
      "jobType": "pic_split",
      "stepDescript": "对输入的HE明场染色图执行H&E预设矩阵颜色反卷积，拆分细胞核、细胞质和背景残留三个通道。",
      "inputs": {
        "imageModality": "brightfield",
        "sourceImageType": "single_rgb_brightfield_image"
      },
      "outputs": {
        "generatedChannels": [
          "ch0",
          "ch1",
          "ch2"
        ]
      },
      "picSplitPlan": {
        "splitMethod": "color_deconvolution",
        "colorDeconvParams": {
          "matrix": "H&E"
        },
        "channelMapping": {
          "ch0": "苏木精（细胞核）",
          "ch1": "伊红（细胞质）",
          "ch2": "背景残留"
        },
        "recommended": true,
        "outputOptions": {
          "returnChannelStoredFiles": true,
          "returnChannelBase64": false
        }
      }
    },
    {
      "jobId": "job_01",
      "jobName": "建立全空泡候选target",
      "jobType": "create_target",
      "stepDescript": "在伊红细胞质通道上使用Cellpose zhijing_vacuoles模型分割所有空泡候选区域，建立tg1作为基础空泡集合。",
      "inputs": {
        "channelId": [
          "ch1"
        ],
        "sourceTargetNames": []
      },
      "outputs": {
        "targetName": "tg1"
      },
      "createTargetPlan": {
        "recommendedSegmentMethod": "cellpose",
        "segmentMethodReason": "空泡为类圆形结构，zhijing_vacuoles是针对空泡分割优化的Cellpose模型，适合从HE细胞质通道中提取空泡区域。",
        "sourceTargetNames": [],
        "variant": [],
        "variantReasoning": "tg1为直接分割得到的基础空泡target，无需生成空间变体。",
        "measureOn": [],
        "measureFeatures": [],
        "filterConditions": [],
        "filterBasis": "",
        "cellposeParams": {
          "model": "zhijing_vacuoles",
          "diameter": 50.0,
          "flowThreshold": {
            "min": 0.0,
            "max": 1.0
          },
          "cellprobThreshold": {
            "min": -6.0,
            "max": 6.0
          }
        },
        "imagePreprocess": {
          "smooth": 0.0,
          "blur": 0.0,
          "sharp": 0.0,
          "invert": false
        }
      }
    },
    {
      "jobId": "job_02",
      "jobName": "建立小空泡分级target",
      "jobType": "create_target",
      "stepDescript": "基于tg1全空泡集合，测量每个空泡面积，筛选面积在0.0~5029.0 px²的空泡建立tg2。",
      "inputs": {
        "channelId": [
          "ch1"
        ],
        "sourceTargetNames": [
          "tg1"
        ]
      },
      "outputs": {
        "targetName": "tg2"
      },
      "createTargetPlan": {
        "recommendedSegmentMethod": "",
        "segmentMethodReason": "",
        "sourceTargetNames": [
          "tg1"
        ],
        "variant": [],
        "variantReasoning": "按面积属性筛选派生target，无需空间变体。",
        "measureOn": [
          "ch1"
        ],
        "measureFeatures": [
          "AREA"
        ],
        "filterConditions": [
          {
            "channelId": "ch1",
            "feature": "AREA",
            "operator": "between",
            "threshold": {
              "min": 0.0,
              "max": 5029.0
            },
            "reason": "用户指定的小空泡面积分级范围为0.0到5029.0 px²。"
          }
        ],
        "filterBasis": "按空泡面积属性筛选符合指定范围的子集合。"
      }
    },
    {
      "jobId": "job_03",
      "jobName": "建立中空泡分级target",
      "jobType": "create_target",
      "stepDescript": "基于tg1全空泡集合，测量每个空泡面积，筛选面积在5029.0~12909.0 px²的空泡建立tg3。",
      "inputs": {
        "channelId": [
          "ch1"
        ],
        "sourceTargetNames": [
          "tg1"
        ]
      },
      "outputs": {
        "targetName": "tg3"
      },
      "createTargetPlan": {
        "recommendedSegmentMethod": "",
        "segmentMethodReason": "",
        "sourceTargetNames": [
          "tg1"
        ],
        "variant": [],
        "variantReasoning": "按面积属性筛选派生target，无需空间变体。",
        "measureOn": [
          "ch1"
        ],
        "measureFeatures": [
          "AREA"
        ],
        "filterConditions": [
          {
            "channelId": "ch1",
            "feature": "AREA",
            "operator": "between",
            "threshold": {
              "min": 5029.0,
              "max": 12909.0
            },
            "reason": "用户指定的中空泡面积分级范围为5029.0到12909.0 px²。"
          }
        ],
        "filterBasis": "按空泡面积属性筛选符合指定范围的子集合。"
      }
    },
    {
      "jobId": "job_99",
      "jobName": "统计各分级空泡数量",
      "jobType": "formula",
      "stepDescript": "统计tg1总空泡数、tg2小空泡数、tg3中空泡数，输出分级计数结果。",
      "inputs": {
        "targetInputs": [
          {
            "targetName": "tg1",
            "metric": "COUNT",
            "role": "total_vacuole_count"
          },
          {
            "targetName": "tg2",
            "metric": "COUNT",
            "role": "small_vacuole_count"
          },
          {
            "targetName": "tg3",
            "metric": "COUNT",
            "role": "medium_vacuole_count"
          }
        ]
      },
      "outputs": {
        "resultName": "vacuole_grading_count_summary"
      },
      "formulaPlan": {
        "expression": "totalVacuoleCount = tg1.COUNT; smallVacuoleCount = tg2.COUNT; mediumVacuoleCount = tg3.COUNT",
        "reportFields": [
          {
            "fieldName": "totalVacuoleCount",
            "displayName": "总空泡数量",
            "unit": "个",
            "description": "分割得到的所有空泡候选区域总数量。"
          },
          {
            "fieldName": "smallVacuoleCount",
            "displayName": "小空泡数量（0~5029px²）",
            "unit": "个",
            "description": "面积在0.0~5029.0 px²范围内的空泡数量。"
          },
          {
            "fieldName": "mediumVacuoleCount",
            "displayName": "中空泡数量（5029~12909px²）",
            "unit": "个",
            "description": "面积在5029.0~12909.0 px²范围内的空泡数量。"
          }
        ]
      }
    }
  ]
}