{
  "experimentName": "肝脏SMA免疫组化H-score分析",
  "inputMode": "single_rgb_brightfield_image",
  "analysisGoal": "计算图片中SMA染色的H-score",
  "imageInference": {
    "imageModality": "brightfield_ihc",
    "experimentType": "tissue_region_analysis,intensity_score_analysis",
    "reasoning": [
      "图像为明场免疫组化染色图，蓝色为苏木精染色的细胞核，棕色为SMA的DAB染色阳性区域，属于肝脏组织切片",
      "本Workplan按DAB解卷灰度通道中强阳性染色区域灰度值较低、背景灰度值较高的常见语义设计阈值和H-score公式",
      "SMA H-score按面积分级口径计算，将DAB-SMA阳性区域按低灰度强阳性、中等灰度中阳性、较高灰度弱阳性三个等级分别分割"
    ]
  },
  "workplanSceneType": "target_based_analysis",
  "channels": [
    {
      "channelId": "ch0",
      "channelName": "苏木精",
      "semanticRole": "nucleus_channel"
    },
    {
      "channelId": "ch1",
      "channelName": "DAB（SMA）",
      "semanticRole": "positive_signal_channel"
    },
    {
      "channelId": "ch2",
      "channelName": "背景残留",
      "semanticRole": "background_channel"
    }
  ],
  "targets": [
    {
      "targetName": "total_sma_roi",
      "targetType": "total_region_target",
      "description": "图片中所有SMA阳性区域的原始ROI集合"
    },
    {
      "targetName": "weak_sma_roi",
      "targetType": "intensity_region_target",
      "description": "图片中DAB-SMA弱阳性区域ROI集合"
    },
    {
      "targetName": "moderate_sma_roi",
      "targetType": "intensity_region_target",
      "description": "图片中DAB-SMA中阳性区域ROI集合"
    },
    {
      "targetName": "strong_sma_roi",
      "targetType": "intensity_region_target",
      "description": "图片中DAB-SMA强阳性区域ROI集合"
    }
  ],
  "jobs": [
    {
      "jobId": "job_00",
      "jobName": "颜色反卷积拆分通道",
      "jobType": "pic_split",
      "stepDescript": "对输入的明场IHC图像执行颜色反卷积，拆分苏木精、DAB（SMA）和背景残留通道",
      "inputs": {
        "sourceImage": "input_image"
      },
      "outputs": {
        "generatedChannels": [
          "苏木精（细胞核）",
          "DAB（SMA阳性）",
          "背景残留"
        ]
      },
      "picSplitPlan": {
        "splitMethod": "color_deconvolution",
        "colorDeconvParams": {
          "matrix": "H DAB"
        },
        "channelMapping": {
          "ch0": "苏木精（细胞核）",
          "ch1": "DAB（SMA阳性）",
          "ch2": "背景残留"
        },
        "recommended": true
      }
    },
    {
      "jobId": "job_01",
      "jobName": "建立SMA总区域target",
      "jobType": "create_target",
      "stepDescript": "在DAB（SMA）通道上通过低灰度阈值分割图片中所有SMA阳性区域，建立原始SMA总区域ROI集合并绑定为target",
      "inputs": {
        "channelId": [
          "ch1"
        ],
        "sourceTargetNames": []
      },
      "outputs": {
        "targetName": "total_sma_roi"
      },
      "createTargetPlan": {
        "recommendedSegmentMethod": "threshold",
        "segmentMethodReason": "SMA阳性区域为DAB棕色染色区域，在DAB解卷灰度通道中通常表现为低灰度强染色区域，适合使用低灰度阈值分割",
        "sourceTargetNames": [],
        "variant": [],
        "variantReasoning": "",
        "measureOn": [],
        "measureFeatures": [],
        "filterConditions": [],
        "filterBasis": "",
        "thresholdParams": {
          "thresholdMin": 0,
          "thresholdMax": 180
        },
        "imagePreprocess": {
          "smooth": 2,
          "blur": 0,
          "sharp": 0,
          "invert": false
        },
        "binaryPostprocess": {
          "fillHole": false,
          "watershed": false
        },
        "analyzeParticlesParams": {
          "sizeMin": 1,
          "sizeMax": 10000000,
          "circularityMin": 0.0,
          "circularityMax": 1.0,
          "excludeOnEdges": false,
          "includeHoles": true
        }
      }
    },
    {
      "jobId": "job_02",
      "jobName": "建立SMA弱阳性区域target",
      "jobType": "create_target",
      "stepDescript": "在DAB（SMA）通道上通过弱阳性灰度阈值范围分割SMA弱阳性区域，并绑定为弱阳性target",
      "inputs": {
        "channelId": [
          "ch1"
        ],
        "sourceTargetNames": []
      },
      "outputs": {
        "targetName": "weak_sma_roi"
      },
      "createTargetPlan": {
        "recommendedSegmentMethod": "threshold",
        "segmentMethodReason": "DAB解卷灰度通道中阳性越强灰度值越低；弱阳性区域位于SMA阳性范围内但灰度值相对较高，因此使用较高灰度阈值范围分割弱阳性区域",
        "sourceTargetNames": [],
        "variant": [],
        "variantReasoning": "",
        "measureOn": [],
        "measureFeatures": [],
        "filterConditions": [],
        "filterBasis": "",
        "thresholdParams": {
          "thresholdMin": 121,
          "thresholdMax": 180
        },
        "imagePreprocess": {
          "smooth": 2,
          "blur": 0,
          "sharp": 0,
          "invert": false
        },
        "binaryPostprocess": {
          "fillHole": false,
          "watershed": false
        },
        "analyzeParticlesParams": {
          "sizeMin": 1,
          "sizeMax": 10000000,
          "circularityMin": 0.0,
          "circularityMax": 1.0,
          "excludeOnEdges": false,
          "includeHoles": true
        }
      }
    },
    {
      "jobId": "job_03",
      "jobName": "建立SMA中阳性区域target",
      "jobType": "create_target",
      "stepDescript": "在DAB（SMA）通道上通过中阳性灰度阈值范围分割SMA中阳性区域，并绑定为中阳性target",
      "inputs": {
        "channelId": [
          "ch1"
        ],
        "sourceTargetNames": []
      },
      "outputs": {
        "targetName": "moderate_sma_roi"
      },
      "createTargetPlan": {
        "recommendedSegmentMethod": "threshold",
        "segmentMethodReason": "DAB解卷灰度通道中阳性越强灰度值越低；中阳性区域灰度值低于弱阳性区域但高于强阳性区域，因此使用中间灰度阈值范围分割",
        "sourceTargetNames": [],
        "variant": [],
        "variantReasoning": "",
        "measureOn": [],
        "measureFeatures": [],
        "filterConditions": [],
        "filterBasis": "",
        "thresholdParams": {
          "thresholdMin": 81,
          "thresholdMax": 120
        },
        "imagePreprocess": {
          "smooth": 2,
          "blur": 0,
          "sharp": 0,
          "invert": false
        },
        "binaryPostprocess": {
          "fillHole": false,
          "watershed": false
        },
        "analyzeParticlesParams": {
          "sizeMin": 1,
          "sizeMax": 10000000,
          "circularityMin": 0.0,
          "circularityMax": 1.0,
          "excludeOnEdges": false,
          "includeHoles": true
        }
      }
    },
    {
      "jobId": "job_04",
      "jobName": "建立SMA强阳性区域target",
      "jobType": "create_target",
      "stepDescript": "在DAB（SMA）通道上通过强阳性低灰度阈值范围分割SMA强阳性区域，并绑定为强阳性target",
      "inputs": {
        "channelId": [
          "ch1"
        ],
        "sourceTargetNames": []
      },
      "outputs": {
        "targetName": "strong_sma_roi"
      },
      "createTargetPlan": {
        "recommendedSegmentMethod": "threshold",
        "segmentMethodReason": "DAB解卷灰度通道中强阳性染色区域灰度值更低，因此使用低灰度阈值范围分割SMA强阳性区域",
        "sourceTargetNames": [],
        "variant": [],
        "variantReasoning": "",
        "measureOn": [],
        "measureFeatures": [],
        "filterConditions": [],
        "filterBasis": "",
        "thresholdParams": {
          "thresholdMin": 0,
          "thresholdMax": 80
        },
        "imagePreprocess": {
          "smooth": 2,
          "blur": 0,
          "sharp": 0,
          "invert": false
        },
        "binaryPostprocess": {
          "fillHole": false,
          "watershed": false
        },
        "analyzeParticlesParams": {
          "sizeMin": 1,
          "sizeMax": 10000000,
          "circularityMin": 0.0,
          "circularityMax": 1.0,
          "excludeOnEdges": false,
          "includeHoles": true
        }
      }
    },
    {
      "jobId": "job_99",
      "jobName": "计算SMA H-score",
      "jobType": "formula",
      "stepDescript": "基于SMA弱阳性、中阳性和强阳性区域面积，计算图片中SMA染色H-score",
      "inputs": {
        "targetInputs": [
          {
            "targetName": "total_sma_roi",
            "metric": "AREA_SUM",
            "role": "total_sma_area"
          },
          {
            "targetName": "weak_sma_roi",
            "metric": "AREA_SUM",
            "role": "weak_sma_area"
          },
          {
            "targetName": "moderate_sma_roi",
            "metric": "AREA_SUM",
            "role": "moderate_sma_area"
          },
          {
            "targetName": "strong_sma_roi",
            "metric": "AREA_SUM",
            "role": "strong_sma_area"
          }
        ]
      },
      "outputs": {
        "resultName": "sma_hscore_result"
      },
      "formulaPlan": {
        "expression": "weakSmaArea = weak_sma_roi.AREA_SUM; moderateSmaArea = moderate_sma_roi.AREA_SUM; strongSmaArea = strong_sma_roi.AREA_SUM; totalSmaArea = total_sma_roi.AREA_SUM; smaHScore = (1 * weakSmaArea + 2 * moderateSmaArea + 3 * strongSmaArea) / totalSmaArea * 100",
        "reportFields": [
          {
            "fieldName": "smaHScore",
            "displayName": "SMA H-score",
            "unit": "",
            "description": "基于SMA阳性区域面积分级计算的H-score，公式为(1×弱阳性面积 + 2×中阳性面积 + 3×强阳性面积) / SMA阳性总面积 × 100"
          },
          {
            "fieldName": "weakSmaArea",
            "displayName": "SMA弱阳性面积",
            "unit": "px^2",
            "description": "图片中DAB-SMA灰度值处于弱阳性范围的区域面积总和"
          },
          {
            "fieldName": "moderateSmaArea",
            "displayName": "SMA中阳性面积",
            "unit": "px^2",
            "description": "图片中DAB-SMA灰度值处于中阳性范围的区域面积总和"
          },
          {
            "fieldName": "strongSmaArea",
            "displayName": "SMA强阳性面积",
            "unit": "px^2",
            "description": "图片中DAB-SMA灰度值处于强阳性范围的区域面积总和"
          },
          {
            "fieldName": "totalSmaArea",
            "displayName": "SMA阳性总面积",
            "unit": "px^2",
            "description": "图片中所有SMA阳性区域的面积总和"
          }
        ]
      }
    }
  ]
}